{
  "name": "spicetify-playlist-hotkeys",
  "version": "1.0.0",
  "description": "Spicetify extension to add hotkeys for adding current track to specific playlists",
  "main": "index.js",
  "scripts": {
    "build": "spicetify-creator",
    "build:local": "spicetify-creator --out=dist --minify",
    "watch": "spicetify-creator --watch",
    "build:test": "tsup --config tsup.test.config.ts",
    "build:benchmark": "tsup --config tsup.benchmark.config.ts",
    "build:cosmos-test": "tsup --config tsup.cosmos-test.config.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^24.3.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "sass": "^1.93.2",
    "spicetify-creator": "^1.0.17",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "classnames": "^2.5.1",
    "spcr-settings": "^1.3.1"
  }
}
